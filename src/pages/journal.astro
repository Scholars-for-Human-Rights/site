---
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Journal',
};

// Add journal entries here as the organization publishes
const entries = [
  // Example structure:
  // {
  //   title: 'Why Scholars Must Speak',
  //   author: 'SHR Member',
  //   date: 'April 2025',
  //   excerpt: 'An argument for why academic silence in times of crisis is itself a political act...',
  //   href: '#',
  //   tags: ['Opinion', 'Advocacy'],
  // },
];
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero tagline="Journal">
    <Fragment slot="title">
      The SFHR <span class="text-accent dark:text-white">Journal</span>
    </Fragment>
    <Fragment slot="subtitle">
      Essays, analyses, and reflections from scholars committed to human rights. Our journal
      brings academic rigor to the issues we care about most.
    </Fragment>
  </Hero>

  <!-- Journal Entries -->
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    {entries.length === 0 ? (
      <div class="text-center py-16">
        <p class="text-xl text-gray-500 dark:text-gray-400">
          Our first entries are coming soon. We're gathering voices.
        </p>
        <p class="mt-4 text-gray-500 dark:text-gray-400">
          Interested in contributing?
          <a href="/contact" class="text-blue-600 dark:text-blue-400 underline ml-1">Reach out to us</a>.
        </p>
      </div>
    ) : (
      <div class="space-y-10">
        {entries.map((entry) => (
          <article class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex flex-wrap gap-2 mb-3">
              {entry.tags && entry.tags.map((tag) => (
                <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
              <a href={entry.href} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                {entry.title}
              </a>
            </h2>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
              By {entry.author} &bull; {entry.date}
            </p>
            <p class="mt-4 text-gray-600 dark:text-gray-300 leading-relaxed">{entry.excerpt}</p>
            <a
              href={entry.href}
              class="inline-block mt-4 text-sm font-semibold text-blue-600 dark:text-blue-400 hover:underline"
            >
              Read more &rarr;
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Submit a piece',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">Want to contribute?</Fragment>
    <Fragment slot="subtitle">
      We welcome essays, analyses, opinion pieces, and research from scholars across Boston universities.
      Get in touch to discuss your submission.
    </Fragment>
  </CallToAction>
</Layout>
