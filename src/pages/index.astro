---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';

const metadata = {
  title: 'Scholars for Human Rights',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Get Involved',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
      { text: 'Learn more', href: '/about' },
    ]}
  >
    <Fragment slot="title">
      Scholars standing up<br />
      <span class="text-accent dark:text-white">for human rights</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">Scholars for Human Rights</span> is a political advocacy and social justice organization
      for PhD, Law, and Professional students across Boston universities. We believe scholars have both the privilege and
      the responsibility to act.
    </Fragment>
  </Hero>

  <!-- Mission -->
  <Content
    isReversed
    items={[
      {
        title: 'Advocacy',
        description:
          'We engage with local, state, and federal issues that affect human rights and democratic institutions.',
        icon: 'tabler:speakerphone',
      },
      {
        title: 'Community',
        description:
          'We build a network of engaged scholars across Boston universities through events and discussions.',
        icon: 'tabler:users',
      },
      {
        title: 'Scholarship',
        description: 'We bring academic rigor to the issues we care about through our journal and research.',
        icon: 'tabler:book',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Scholars working together',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Our mission</h3>
      We are graduate students and professional scholars who refuse to be silent in the face of injustice. Through advocacy,
      community-building, and scholarship, we fight for the rights of all people.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- What we offer -->
  <Features
    tagline="What we do"
    title="How we make an impact"
    subtitle="SFHR operates across Boston universities, bringing scholars together to advocate, organize, and act."
    items={[
      {
        title: 'Events & Gatherings',
        description: 'Regular meetings, panels, and advocacy events open to all members. Both in-person and via Zoom.',
        icon: 'tabler:calendar',
      },
      {
        title: 'The SFHR Journal',
        description: 'A platform for members to publish essays, analyses, and reflections on human rights issues.',
        icon: 'tabler:writing',
      },
      {
        title: 'Cross-University Network',
        description: 'Connecting scholars across Boston-area universities to build a broader coalition.',
        icon: 'tabler:network',
      },
      {
        title: 'Political Advocacy',
        description: 'Organized action on issues affecting human rights, civil liberties, and democratic governance.',
        icon: 'tabler:flag',
      },
      {
        title: 'Welcoming Community',
        description: 'We welcome people in their whole selves — partners, kids, and everyone who cares.',
        icon: 'tabler:heart',
      },
      {
        title: 'Informed Action',
        description: 'We use the tools of scholarship — research, analysis, communication — to advocate effectively.',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <!-- Who can join -->
  <Features2
    tagline="Membership"
    title="Who can join?"
    subtitle="SFHR is open to PhD, Law, and Professional students across Boston-area universities."
    items={[
      {
        title: 'PhD Candidates',
        description: 'Doctoral students across all disciplines and departments.',
        icon: 'tabler:school',
      },
      {
        title: 'Law Students',
        description: 'Students at Boston-area law schools who care about justice.',
        icon: 'tabler:scale',
      },
      {
        title: 'Professional Students',
        description: 'Graduate students in medicine, public policy, social work, and other professional programs.',
        icon: 'tabler:briefcase',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get in touch',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title"> Ready to join the fight? </Fragment>
    <Fragment slot="subtitle">
      Every day brings another piece of difficult news — but there are many of us who care and aren't willing to go down
      without a fight. Join us.
    </Fragment>
  </CallToAction>
</Layout>
