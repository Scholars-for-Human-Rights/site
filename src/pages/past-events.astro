---
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Past Events',
};

const events = [
  {
    title: 'Founding Informational Meeting',
    date: 'April 15, 2025',
    time: '5:00 – 6:00 PM',
    location: 'Boston + Zoom',
    description:
      'Our founding meeting, where members came together to discuss the mission of Scholars for Human Rights, brainstorm issues and actions, and plan next steps. Key discussions included advocacy for international students, academic freedom, and how to organize safely and effectively across universities.',
    tags: ['Founding', 'Informational'],
  },
  {
    title: 'Mission & Vision Drafting Meeting',
    date: 'June 5, 2025',
    time: '2:00 – 4:00 PM',
    location: 'Zoom',
    description:
      'A two-hour working session focused on drafting our organizational by-laws and vision statement. Members collaborated on language and core principles that would guide the organization going forward.',
    tags: ['Organizational'],
  },
  {
    title: 'Mission Statement Finalization Meeting',
    date: 'June 25, 2025',
    time: '2:00 – 3:30 PM',
    location: 'Zoom',
    description:
      'Members reviewed and refined draft statements and began work on determining consistent meeting structures and potential locations for future in-person gatherings.',
    tags: ['Organizational'],
  },
  {
    title: 'No Kings / Pride Parade',
    date: 'June 14, 2025',
    time: '11:00 AM',
    location: 'Copley Square / Boston Common',
    description:
      'SHR members joined the No Kings Protest and Pride Parade in Boston, marching alongside thousands of others in defense of democratic values and LGBTQ+ rights.',
    tags: ['Protest', 'Community'],
  },
  {
    title: 'Vision & Mission Review Meeting',
    date: 'July 16, 2025',
    time: '12:00 – 1:30 PM',
    location: 'Zoom',
    description:
      'Members reviewed community feedback on the draft vision and mission statements and made final edits to produce the finalized versions adopted by the organization.',
    tags: ['Organizational'],
  },
  {
    title: 'Leadership Committee Formation Meeting',
    date: 'August 22, 2025',
    time: '10:30 AM',
    location: 'Zoom',
    description:
      'The group confirmed the new leadership committee roles (Events Planner, Social Media Chair, Community Liaison, Policy Tracker, Internal Administrator) and planned for the fall semester ahead.',
    tags: ['Organizational', 'Leadership'],
  },
  {
    title: 'Informational Session for New Members',
    date: 'September 29, 2025',
    time: '4:00 – 5:30 PM',
    location: 'Boston + Zoom',
    description:
      "An open information session for interested and new members to learn about SHR's guiding principles, vision and mission statements, and the work accomplished over the summer. Current members were encouraged to attend to reconnect and share updates.",
    tags: ['Informational', 'New Members'],
  },
  {
    title: 'ICE Watch & Know Your Rights Training',
    date: 'September 9, 2025',
    time: '5:00 – 7:00 PM',
    location: 'Boston',
    description:
      'Hosted by Eagles Against Genocide in response to a marked ICE vehicle spotted on campus. SHR members attended as a group to learn their rights and support the campus community.',
    tags: ['Community', 'Training'],
  },
  {
    title: 'No Kings Protest',
    date: 'October 18, 2025',
    time: '12:00 PM',
    location: 'Boston Common (meet at AMC Theater, 175 Tremont St at 11:30 AM)',
    description:
      'SHR members joined the second major No Kings protest in downtown Boston, marching with signs and community. Members documented the day with photos and short videos for the SHR Instagram.',
    tags: ['Protest', 'Community'],
  },
  {
    title: 'Letter Writing Party',
    date: 'November 14, 2025',
    time: '3:30 – 5:00 PM',
    location: 'Boston',
    description:
      'Members gathered to write letters to Mayor Wu, Governor Healey, MA senators, and Congress representatives. Paper, envelopes, stamps, pizza, and drinks were provided.',
    tags: ['Advocacy', 'Community'],
  },
  {
    title: 'Food Drive Launch',
    date: 'November 2025',
    time: 'Ongoing',
    location: 'Boston',
    description:
      'SHR placed donation boxes in multiple departments for non-perishable goods, toiletries, and menstrual products, with QR codes for monetary donations to the Centre Street Food Pantry, Brookline Food Bank, and Greater Boston Food Bank.',
    tags: ['Community', 'Material Support'],
  },
  {
    title: 'End of Semester Celebration',
    date: 'December 5, 2025',
    time: '7:00 PM',
    location: 'TBD, Boston',
    description:
      'An end-of-semester gathering to celebrate the first full semester of SHR and recognize the incredible work members accomplished throughout a challenging year.',
    tags: ['Social', 'Community'],
  },
];
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero tagline="Events">
    <Fragment slot="title">
      Past <span class="text-accent dark:text-white">Events</span>
    </Fragment>
    <Fragment slot="subtitle">
      A record of our gatherings, protests, trainings, and community actions. Our history reflects who we are and what
      we stand for.
    </Fragment>
  </Hero>

  <!-- Events List -->
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div class="space-y-8">
      {
        events.map((event) => (
          <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 p-8 shadow-sm">
            <div class="flex flex-wrap gap-2 mb-3">
              {event.tags &&
                event.tags.map((tag) => (
                  <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300">
                    {tag}
                  </span>
                ))}
            </div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">{event.title}</h2>
            <p class="mt-1 text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">
              {event.date} &bull; {event.time}
            </p>
            <p class="text-sm text-gray-500 dark:text-gray-400">{event.location}</p>
            <p class="mt-3 text-gray-600 dark:text-gray-300 leading-relaxed">{event.description}</p>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
