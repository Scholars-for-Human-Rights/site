---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Us',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero tagline="About Us">
    <Fragment slot="title">
      Scholars standing up<br />
      <span class="text-accent dark:text-white">for human rights</span>
    </Fragment>
    <Fragment slot="subtitle">
      Scholars for Human Rights is a community of doctoral and professional students from across
      Boston universities who are committed to the advancement and protection of scholarship for social justice.
    </Fragment>
  </Hero>

  <!-- Vision & Mission -->
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div class="space-y-10">
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 p-8 shadow-sm">
        <h2 class="text-xl font-bold uppercase tracking-widest text-blue-600 dark:text-blue-400 mb-4">Vision Statement</h2>
        <blockquote class="text-lg leading-relaxed text-gray-700 dark:text-gray-200 italic border-l-4 border-blue-400 pl-6">
          Scholars for Human Rights is committed to building a just and equitable world centered in empathy and community.
          SHR seeks to respect the dignity of all students, workers, and communities who make learning, understanding, and
          education possible. We operate under the belief that we are all interconnected and emphasize growth through
          caring for the whole person.
        </blockquote>
      </div>

      <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 p-8 shadow-sm">
        <h2 class="text-xl font-bold uppercase tracking-widest text-blue-600 dark:text-blue-400 mb-4">Mission Statement</h2>
        <blockquote class="text-lg leading-relaxed text-gray-700 dark:text-gray-200 italic border-l-4 border-blue-400 pl-6">
          SHR is committed to providing material and organizational support to value-aligned groups endeavoring to uplift
          and protect their communities. We work to amplify equitable and compassionate policies that are attuned to how
          systemic injustices continue to shape the present. We seek to create spaces for individuals to share knowledge,
          build understanding, and educate one another on current issues.
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <Content
    isReversed
    items={[
      {
        title: 'How we started',
        description:
          'SHR was founded in spring 2025 by a group of graduate students in response to alarming changes in the federal government. What began as an email grew into a community of scholars who refuse to stay silent.',
      },
      {
        title: 'Who we are',
        description:
          'We are PhD candidates, law students, and professional students from universities across Boston, united by a commitment to human rights, democratic values, and the belief that scholars have both the privilege and responsibility to act.',
      },
      {
        title: 'Our intention',
        description:
          'We intend to outlast the present moment. SHR is built to be a lasting organization — not just a response to one administration, but a permanent community of engaged scholars.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Scholars meeting together',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Our story</h3>
      From a single email in April 2025 to a growing organization with a mission, vision, leadership structure,
      and a record of action — we built this from scratch, together.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Issues we work on -->
  <Features2
    tagline="Our focus areas"
    title="Issues we work on"
    subtitle="SHR engages with a range of issues where scholar voices and advocacy can make a difference."
    items={[
      {
        title: 'Racial Justice',
        description: 'Challenging systemic racism in institutions, policy, and practice.',
        icon: 'tabler:scale',
      },
      {
        title: 'Gender, Safety & Equity',
        description: 'Advocating for gender equity and safety in academic and public life.',
        icon: 'tabler:shield',
      },
      {
        title: 'LGBTQ+ Rights',
        description: 'Standing with LGBTQ+ communities against discrimination and erasure.',
        icon: 'tabler:heart',
      },
      {
        title: 'Academic Freedom',
        description: 'Defending the freedom to research, teach, and publish without political interference.',
        icon: 'tabler:book',
      },
      {
        title: 'Worker & Immigrant Rights',
        description: 'Supporting workers, international students, and immigrant communities facing increasing vulnerability.',
        icon: 'tabler:users',
      },
      {
        title: 'Class Inequality',
        description: 'Addressing economic injustice and advocating for equitable access to resources and opportunity.',
        icon: 'tabler:building-community',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- What we do -->
  <Steps2
    title="How we act"
    subtitle="SHR takes action across several areas."
    items={[
      {
        title: 'Political Advocacy',
        description:
          'We engage with city, state, and federal government — writing letters, attending hearings, and connecting with representatives like Boston City Council and Congress members.',
      },
      {
        title: 'Community Engagement',
        description:
          'We host workshops, teach-ins, Know Your Rights trainings, and partner with aligned organizations to bring resources to campuses and communities.',
      },
      {
        title: 'Material Support',
        description:
          'We organize food drives, letter-writing events, and direct support initiatives for vulnerable community members — including international students and food-insecure neighbors.',
      },
      {
        title: 'Writing & Research',
        description:
          'We provide a platform for scholars to write about social justice issues, demonstrating the public value of higher education and graduate scholarship.',
      },
      {
        title: 'Social Media & Outreach',
        description:
          'We maintain a presence on Instagram and other platforms to share our work, amplify advocacy, and connect with the broader community.',
      },
    ]}
  />

  <!-- Leadership structure -->
  <Features2
    tagline="Organization"
    title="Our leadership committee"
    subtitle="SHR is led by a collective leadership committee where every role carries equal decision-making power."
    items={[
      {
        title: 'Events Planner',
        description: 'Plans events on campus and in the community — from Know Your Rights trainings to social gatherings.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Social Media Chair',
        description: 'Manages SHR social media platforms and website updates.',
        icon: 'tabler:brand-instagram',
      },
      {
        title: 'Community Liaison',
        description: 'Builds and maintains relationships with aligned community organizations (ACLU MA, LUCE, etc.).',
        icon: 'tabler:network',
      },
      {
        title: 'Policy Tracker',
        description: 'Monitors new policies from Boston City Hall, the state legislature, and federal government.',
        icon: 'tabler:news',
      },
      {
        title: 'Internal Administrator',
        description: 'Manages the SHR email account, answers inquiries, and onboards new members.',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get in touch',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">Ready to get involved?</Fragment>
    <Fragment slot="subtitle">
      Everyone is welcome at every meeting, whether you've attended before or not.
      There are no barriers to starting whenever you can.
    </Fragment>
  </CallToAction>
</Layout>
