---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Get in touch"
    subtitle="We'd love to hear from you — whether you want to join, have a question, or want to get your university involved."
  />

  <ContactUs
    id="form"
    title="Send us a message"
    subtitle="Fill out the form below and we'll get back to you as soon as we can."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
      {
        type: 'text',
        name: 'university',
        label: 'University / Program (optional)',
      },
    ]}
    textarea={{
      label: 'Message',
      placeholder: 'Tell us a bit about yourself and why you\'re reaching out...',
    }}
    disclaimer={{
      label: 'By submitting this form, you agree to us using your information to respond to your inquiry.',
    }}
    description="We typically respond within a few days."
  />

  <Features2
    title="Other ways to reach us"
    items={[
      {
        title: 'Email',
        description: 'mccoymi@bc.edu',
        icon: 'tabler:mail',
      },
      {
        title: 'Who can join?',
        description: 'PhD, Law, and Professional students across Boston-area universities are all welcome.',
        icon: 'tabler:users',
      },
      {
        title: 'Hybrid access',
        description: 'All events are available in-person and via Zoom, so distance is never a barrier.',
        icon: 'tabler:video',
      },
    ]}
  />
</Layout>
